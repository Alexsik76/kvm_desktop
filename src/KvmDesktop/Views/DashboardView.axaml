<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:KvmDesktop.ViewModels"
             xmlns:models="using:KvmDesktop.Models"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="KvmDesktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    
    <DockPanel Margin="20">
        <!-- Header -->
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="KVM Nodes Dashboard" FontSize="20" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding WelcomeMessage}" FontSize="12" Opacity="0.7"/>
            </StackPanel>
            
            <Button Grid.Column="1" 
                    Command="{Binding LogoutCommand}" 
                    Content="Logout" 
                    Theme="{StaticResource ButtonLowInk}"/>
        </Grid>

        <!-- Refresh / Loading -->
        <Grid DockPanel.Dock="Bottom" Margin="0,10,0,0">
            <Button Command="{Binding LoadNodesCommand}" 
                    Content="Refresh List" 
                    HorizontalAlignment="Right" 
                    IsEnabled="{Binding !IsBusy}"/>
            <ProgressBar IsIndeterminate="True" 
                         IsVisible="{Binding IsBusy}" 
                         Height="2" 
                         VerticalAlignment="Bottom"/>
        </Grid>

        <!-- Nodes List -->
        <ListBox ItemsSource="{Binding Nodes}" 
                 SelectedItem="{Binding SelectedNode}"
                 Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:KvmNode">
                    <Border Padding="10" Margin="2" CornerRadius="4" Background="{DynamicResource SystemChromeLowColor}">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding Id}" FontSize="10" Opacity="0.5"/>
                            </StackPanel>
                            
                            <Border Grid.Column="1" 
                                    Background="{DynamicResource SystemChromeMediumColor}" 
                                    CornerRadius="4" 
                                    Padding="8,4" 
                                    Margin="20,0">
                                <TextBlock Text="{Binding Status}" 
                                           FontSize="12" 
                                           VerticalAlignment="Center"/>
                            </Border>

                            <Button Grid.Column="2" 
                                    Content="Connect" 
                                    Command="{Binding $parent[UserControl].((vm:DashboardViewModel)DataContext).LaunchNodeCommand}" 
                                    CommandParameter="{Binding}"
                                    Classes="accent"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
